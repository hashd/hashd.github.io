---
const navItems: Array<{ href: string; label: string }> = [
  { href: '/writing/', label: 'Writing' },
  { href: '/tags/', label: 'Tags' },
  { href: '/projects/', label: 'Projects' },
  { href: '/resume/', label: 'Resume' }
];
const { pathname } = Astro.url;
---

<header class="site-header" id="siteHeader">
  <div class="chrome header-inner">
    <a class="brand" href="/">
      <img class="avatar" src="/logo.png" alt="" aria-hidden="true" />
      <span class="brand-text">
        <span class="brand-name">Kiran Danduprolu</span>
        <span class="brand-sub">Engineering Leader · systems &amp; backend</span>
      </span>
    </a>
    <nav class="primary" aria-label="Primary">
      {
        navItems.map((i) => (
          <a href={i.href} class={pathname.startsWith(i.href) ? 'active' : ''}>
            {i.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: var(--sp-4);
    z-index: 50;
    margin: 0 auto;
    max-width: var(--chrome-max);
    padding: 0 var(--sp-4);
    transition: transform var(--dur-mid) var(--ease-spring);
  }
  .chrome.header-inner {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-2) var(--sp-3);
    margin: 0 auto;
    background: var(--surface-solid);
    border: 2px solid var(--text);
    border-radius: 0;
    box-shadow: 4px 4px 0 var(--text);
    transition: box-shadow var(--dur-mid) var(--ease-out), transform var(--dur-fast) var(--ease-spring);
  }
  .site-header.scrolled .chrome.header-inner {
    box-shadow: 6px 6px 0 var(--accent);
    transform: translate(-2px, -2px);
  }
  
  .brand {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--text);
    padding: var(--sp-1);
    transition: background-color var(--dur-fast) var(--ease-out);
  }
  .brand:hover {
    text-decoration: none;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 0;
    object-fit: cover;
    background: var(--surface-solid);
    border: 2px solid var(--text);
    transition: transform var(--dur-fast) var(--ease-spring), border-color var(--dur-fast) var(--ease-out);
  }
  .brand-text {
    display: flex;
    flex-direction: column;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--fs-md);
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  nav.primary {
    margin-left: auto;
    display: flex;
    gap: var(--sp-2);
  }
  nav.primary a {
    position: relative;
    color: var(--text);
    font-weight: 600;
    font-size: 14px;
    padding: var(--sp-2) var(--sp-3);
    border-radius: 0;
    border: 2px solid transparent;
    transition: color var(--dur-fast) var(--ease-out), background-color var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
  }
  nav.primary a:hover {
    color: var(--surface-solid);
    background-color: var(--text);
    text-decoration: none;
    transform: translate(-2px, -2px);
    box-shadow: 2px 2px 0 var(--accent);
  }
  nav.primary a:active {
    transform: translateY(0);
    box-shadow: 0 0 0 transparent;
  }
  nav.primary a.active {
    border-color: var(--text);
    background-color: transparent;
    color: var(--text);
  }
</style>
