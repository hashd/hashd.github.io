---
import PostLayout from '../layouts/PostLayout.astro';
import { getAllPublishedPosts, getAdjacentLivePosts, postHref, type Post } from '../lib/posts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getAllPublishedPosts();
  return posts.map((post) => ({
    params: { slug: postHref(post).replace(/^\/|\/$/g, '') },
    props: { post },
  }));
};

interface Props { post: Post; }
const { post } = Astro.props as Props;
const { Content } = await post.render();
const { prev, next } = await getAdjacentLivePosts(post);
---
<PostLayout post={post} body={post.body} prev={prev} next={next}>
  <Content />
</PostLayout>
