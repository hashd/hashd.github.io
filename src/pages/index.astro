---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getLivePosts, getArchivedPosts, getFeaturedLivePosts } from '../lib/posts';

const featured = await getFeaturedLivePosts();
const live = (await getLivePosts())
  .filter((p) => !featured.includes(p))
  .slice(0, 6 - featured.length);
const archived = (await getArchivedPosts()).slice(0, 3);
---

<BaseLayout title="Kiran Danduprolu" description="Notes on systems, types, and the craft of code.">
  <div class="content">
    <section class="hero">
      <div class="intro-label">kiran.danduprolu.com</div>
      <h1>Notes on systems, types,<br />and the craft of code.</h1>
      <p class="lede">
        A writing-forward corner of the internet. Mostly backend, occasionally functional, sometimes
        a yak getting shaved in public.
      </p>
    </section>

    <div class="section-title">
      <h2>Latest</h2>
      <a class="see-all" href="/writing/">All writing →</a>
    </div>

    <div class="cards">
      {featured.map((p) => <PostCard post={p} featured />)}
      {live.map((p) => <PostCard post={p} />)}
      {
        live.length === 0 && featured.length === 0 && (
          <p class="empty">New posts coming soon. In the meantime, the archive is below.</p>
        )
      }
    </div>

    {
      archived.length > 0 && (
        <>
          <div class="section-title">
            <h2>From the archive</h2>
            <a class="see-all" href="/writing/">
              See all →
            </a>
          </div>
          <div class="cards archive">
            {archived.map((p) => (
              <PostCard post={p} />
            ))}
          </div>
        </>
      )
    }
  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--sp-5) 0 var(--sp-4);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    margin-top: var(--sp-7);
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -16px; left: -64px; right: -64px; bottom: -16px;
    background: var(--surface-solid);
    border: 2px solid var(--text);
    box-shadow: 8px 8px 0 var(--accent);
    z-index: -1;
    transform: rotate(-0.5deg);
    animation: curtain-up var(--dur-xslow) var(--ease-spring) both;
  }
  @media (max-width: 768px) {
    .hero::before {
      left: -20px; right: -20px;
    }
  }
  .intro-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--surface-solid);
    background: var(--text);
    padding: var(--sp-1) var(--sp-2);
    margin-bottom: var(--sp-3);
    border-radius: 0;
    box-shadow: 3px 3px 0 var(--accent-warm);
    animation: curtain-up var(--dur-xslow) var(--ease-spring) 100ms both;
  }
  .hero h1 {
    margin: 0 0 var(--sp-3);
    font-size: var(--fs-3xl);
    font-family: var(--font-display);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--text);
    text-transform: uppercase;
    animation: curtain-up var(--dur-xslow) var(--ease-spring) 200ms both;
  }
  .hero .lede {
    margin: 0;
    max-width: 680px;
    color: var(--text-muted);
    font-size: var(--fs-lg);
    line-height: 1.4;
    font-weight: 500;
    animation: curtain-up var(--dur-xslow) var(--ease-spring) 300ms both;
  }
  .cards {
    display: grid;
    gap: var(--sp-6);
  }
  .cards.archive {
    opacity: 1;
  }
  .empty {
    color: var(--text-muted);
    background: var(--surface);
    padding: var(--sp-6);
    border: 2px dashed var(--border);
    text-align: center;
    font-family: var(--font-mono);
  }
</style>

<script>
  function wireReveal() {
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.cards .reveal-target'));
    cards.forEach((el, i) => (el.style.transitionDelay = `${Math.min(i, 3) * 60}ms`));
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' },
    );
    cards.forEach((c) => io.observe(c));
    cards.slice(0, 2).forEach((c) => c.classList.add('revealed'));
  }
  document.addEventListener('astro:page-load', wireReveal);
</script>
